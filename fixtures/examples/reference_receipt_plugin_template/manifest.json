{
  "manifest_version": "1",
  "plugin_id": "example.reference_template_receipt_de",
  "plugin_version": "1.0.0",
  "connector_api_version": "1",
  "plugin_family": "receipt",
  "source_id": "reference_template_receipt_de",
  "display_name": "Reference Template Receipt Connector",
  "merchant_name": "Reference Merchant",
  "country_code": "DE",
  "maintainer": "connector-author@example.invalid",
  "license": "MIT",
  "runtime_kind": "subprocess_python",
  "entrypoint": "plugin.py:ReferenceTemplateReceiptPlugin",
  "auth_kind": "browser_session",
  "auth": {
    "auth_kind": "browser_session",
    "supports_live_session_bootstrap": true,
    "supports_reauth": true,
    "supports_headless_refresh": false,
    "supports_manual_confirm": true,
    "supports_oauth_callback": false,
    "supports_session_file": true,
    "implemented_actions": [
      "start_auth",
      "cancel_auth",
      "confirm_auth"
    ],
    "compatibility_actions": [
      "start_auth",
      "cancel_auth"
    ],
    "reserved_actions": [
      "start_auth",
      "cancel_auth",
      "confirm_auth"
    ]
  },
  "capabilities": [
    "healthcheck",
    "historical_sync",
    "discount_classification",
    "live_session_bootstrap",
    "manual_reauth"
  ],
  "trust_class": "community_unsigned",
  "plugin_origin": "external",
  "install_status": "available",
  "compatibility": {
    "min_core_version": "0.1.0",
    "supported_host_kinds": [
      "self_hosted",
      "electron"
    ]
  },
  "config_schema": {
    "fields": [
      {
        "key": "merchant_label",
        "label": "Merchant label",
        "description": "Optional display-name override used in normalized receipts.",
        "input_kind": "text",
        "required": false,
        "sensitive": false
      },
      {
        "key": "auth_timeout_seconds",
        "label": "Auth timeout seconds",
        "description": "Optional timeout for the shared browser bootstrap flow.",
        "input_kind": "number",
        "required": false,
        "sensitive": false,
        "operator_only": true
      }
    ]
  },
  "policy": {
    "trust": {
      "execution_model": "sandboxed",
      "requires_operator_approval": true
    },
    "ai": {
      "allow_model_mediation": false,
      "allow_model_generated_actions": false
    }
  },
  "metadata": {
    "reference_template": true,
    "bootstrap_mode": "plugin_shared_browser_storage_capture",
    "template_notes": [
      "Replace fixture URLs and receipt fixtures with merchant-specific implementations.",
      "Persist plugin state under context.storage instead of core-side source resolvers."
    ]
  }
}
