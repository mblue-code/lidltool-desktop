{
  "name": "lidltool-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron side-app scaffold for one-time retailer scrapes and local analysis",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "vendor:sync": "node ./scripts/sync-vendor.mjs && npm run vendor:patch-frontend && npm run vendor:patch-backend && npm run i18n:sync-shell",
    "vendor:patch-frontend": "node ./scripts/patch-vendored-frontend.mjs",
    "vendor:patch-backend": "node ./scripts/patch-vendored-backend.mjs",
    "i18n:sync-shell": "node ./scripts/sync-shell-i18n.mjs",
    "frontend:install": "npm --prefix ./vendor/frontend ci",
    "frontend:build": "npm run vendor:patch-frontend && npm --prefix ./vendor/frontend run build",
    "backend:prepare": "node ./scripts/prepare-backend.mjs",
    "assets:sync": "node ./scripts/sync-assets.mjs",
    "dev": "npm run i18n:sync-shell && electron-vite dev",
    "dev:full": "npm run vendor:sync && npm run frontend:install && npm run backend:prepare && npm run frontend:build && electron-vite dev",
    "build": "npm run i18n:sync-shell && npm run assets:sync && electron-vite build",
    "build:full-ui": "npm run frontend:install && npm run frontend:build && npm run assets:sync && electron-vite build",
    "test:e2e:prepare": "npm run backend:prepare && npm run frontend:build && npm run build",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --headed --config=playwright.config.ts",
    "test:e2e:full": "npm run test:e2e:prepare && npm run test:e2e",
    "test:control-center": "node --test --experimental-strip-types tests/control-center-model.test.ts",
    "test:plugin-packs": "node --test --experimental-strip-types tests/receipt-plugin-packs.test.ts",
    "test:release-metadata": "node --test --experimental-strip-types tests/release-metadata.test.ts",
    "test:trusted-distribution": "node --test --experimental-strip-types tests/control-center-model.test.ts tests/receipt-plugin-packs.test.ts tests/release-metadata.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:with-backend": "npm run backend:prepare && npm run build && electron-builder",
    "dist:full": "npm run vendor:sync && npm run backend:prepare && npm run build:full-ui && electron-builder"
  },
  "build": {
    "appId": "com.lidltool.desktop",
    "productName": "LidlTool Desktop",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/frontend-dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/backend-venv",
        "to": "backend-venv",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/backend-src",
        "to": "backend-src",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "extraMetadata": {
      "main": "out/main/index.js"
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
