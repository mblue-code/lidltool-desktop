{
  "name": "outlays-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "VITE_APP_MODE=demo_snapshot VITE_BASE_PATH=/outlays/demo/ npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:a11y": "vitest run src/pages/__tests__/a11y-critical.test.tsx",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:headed": "npx playwright test --headed --config=playwright.config.ts",
    "quality:phase6": "npm test && npm run test:a11y && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@json-render/core": "^0.11.0",
